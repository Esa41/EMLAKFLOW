# ── Neon (PostgreSQL) ──
# Pooled (runtime) — serverless icin pgbouncer
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.eu-central-1.aws.neon.tech/emlakflow?sslmode=require&pgbouncer=true"
# Direct (prisma migrate)
DIRECT_URL="postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/emlakflow?sslmode=require"

# ── NextAuth ──
# uret: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ── Cloudflare R2 (Faz 1'de opsiyonel — portfoy medya yuklemede devreye girecek) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="emlakflow-media"
R2_PUBLIC_URL="https://media.emlakflow.app"

# ── Analitik cron güvenliği (Vercel Cron otomatik gönderir) ──
# uret: openssl rand -hex 16
CRON_SECRET=""

# ── Yapay Zeka (OpenAI — AI İlan Asistanı) ──
# https://platform.openai.com/api-keys adresinden alabilirsiniz
OPENAI_API_KEY=""

# ── Mapbox (3D Drone Harita Görünümü) ──
# https://account.mapbox.com/ adresinden ücretsiz token alabilirsiniz
NEXT_PUBLIC_MAPBOX_TOKEN=""
