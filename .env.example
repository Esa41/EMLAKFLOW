# ── Neon (PostgreSQL) ──
# Pooled (runtime) — serverless icin pgbouncer
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.eu-central-1.aws.neon.tech/emlakflow?sslmode=require&pgbouncer=true"
# Direct (prisma migrate)
DIRECT_URL="postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/emlakflow?sslmode=require"

# Canlı site adresi (vitrin, sitemap, feed — AUTH_URL'den ayrı tutulmalı)
# Örn: https://emlakflow.vercel.app veya https://emlakflow.com
NEXT_PUBLIC_APP_URL=""

# ── NextAuth ──
# uret: openssl rand -base64 32
AUTH_SECRET=""
# Yerel geliştirme için; canlıda Vercel otomatik AUTH_URL atar
AUTH_URL="http://localhost:3000"

# ── Super-admin (/admin paneli erişimi) ──
# Virgülle ayrılmış e-posta listesi. Bu e-postalarla giriş yapanlar
# /admin panelinden ofisleri Pro/Free yapabilir.
SUPER_ADMIN_EMAILS="seninmail@ornek.com"

# ── Cloudflare R2 (Faz 1'de opsiyonel — portfoy medya yuklemede devreye girecek) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="emlakflow-media"
R2_PUBLIC_URL="https://media.emlakflow.app"

# ── Analitik cron güvenliği (Vercel Cron otomatik gönderir) ──
# uret: openssl rand -hex 16
CRON_SECRET=""

# ── Yapay Zeka (OpenAI — AI İlan Asistanı) ──
# https://platform.openai.com/api-keys adresinden alabilirsiniz
OPENAI_API_KEY=""

# ── Mapbox (vitrin haritası + drone görünüm) ──
# https://account.mapbox.com/ adresinden ücretsiz token alabilirsiniz
NEXT_PUBLIC_MAPBOX_TOKEN=""
# Opsiyonel: Mapbox Studio'da yayınladığınız özel stil URL'si (yoksa streets-v12 + PARSEL tema)
# NEXT_PUBLIC_MAPBOX_STYLE="mapbox://styles/kullanici/emlakflow-vitrin"

# ── Meta / Instagram (İçerik Takibi — sosyal senkron) ──
# https://developers.facebook.com/apps → yeni "Business" tipi uygulama
# OAuth redirect URI olarak şunu ekleyin:
#   Yerel:  http://localhost:3000/api/social/callback
#   Canlı:  https://<alan-adiniz>/api/social/callback
# Instagram hesabı bir Facebook Sayfası'na bağlı "Business/Creator" olmalı.
META_APP_ID=""
META_APP_SECRET=""

# E-posta (şifre sıfırlama) — resend.com'dan API key; boşsa dev'de link konsola yazılır
RESEND_API_KEY=""
MAIL_FROM="EmlakFlow <noreply@emlakflow.app>"
