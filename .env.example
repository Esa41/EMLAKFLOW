# ── Neon (PostgreSQL) ──
# Pooled (runtime) — serverless icin pgbouncer
DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.eu-central-1.aws.neon.tech/emlakflow?sslmode=require&pgbouncer=true"
# Direct (prisma migrate)
DIRECT_URL="postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/emlakflow?sslmode=require"

# Canlı site adresi (vitrin, sitemap, feed — AUTH_URL'den ayrı tutulmalı)
# Örn: https://emlakflow.vercel.app veya https://emlakflow.com
NEXT_PUBLIC_APP_URL=""

# ── NextAuth ──
# uret: openssl rand -base64 32
AUTH_SECRET=""
# Yerel geliştirme için; canlıda Vercel otomatik AUTH_URL atar
AUTH_URL="http://localhost:3000"

# ── Super-admin (/admin paneli erişimi) ──
# Virgülle ayrılmış e-posta listesi. Bu e-postalarla giriş yapanlar
# /admin panelinden ofisleri Pro/Free yapabilir.
SUPER_ADMIN_EMAILS="seninmail@ornek.com"

# ── Cloudflare R2 (Faz 1'de opsiyonel — portfoy medya yuklemede devreye girecek) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="emlakflow-media"
R2_PUBLIC_URL="https://media.emlakflow.app"

# ── Analitik cron güvenliği (Vercel Cron otomatik gönderir) ──
# uret: openssl rand -hex 16
CRON_SECRET=""

# ── Yapay Zeka (OpenAI — AI İlan Asistanı) ──
# https://platform.openai.com/api-keys adresinden alabilirsiniz
OPENAI_API_KEY=""

# ── Mapbox (vitrin haritası + drone görünüm) ──
# https://account.mapbox.com/ adresinden ücretsiz token alabilirsiniz
NEXT_PUBLIC_MAPBOX_TOKEN=""
# Sunucu tarafı statik görüntü (opsiyonel; yoksa NEXT_PUBLIC_MAPBOX_TOKEN kullanılır)
# MAPBOX_ACCESS_TOKEN=""

# ── AI Drone Video (Mapbox → QStash → Vertex AI Veo → Vercel Blob) ──
# Upstash QStash — https://console.upstash.com/qstash
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Vercel Blob — video depolama (Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=""

# Google Cloud / Vertex AI Veo
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_LOCATION="us-central1"
# Service account JSON (tek satır) — Vertex AI User rolü gerekir
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'
# Veo model (varsayılan: veo-2.0-generate-001)
# VERTEX_AI_VEO_MODEL="veo-3.1-generate-001"

# ── Meta / Instagram (İçerik Takibi — sosyal senkron) ──
# https://developers.facebook.com/apps → yeni "Business" tipi uygulama
# OAuth redirect URI olarak şunu ekleyin:
#   Yerel:  http://localhost:3000/api/social/callback
#   Canlı:  https://<alan-adiniz>/api/social/callback
# Instagram hesabı bir Facebook Sayfası'na bağlı "Business/Creator" olmalı.
META_APP_ID=""
META_APP_SECRET=""

# E-posta (şifre sıfırlama) — resend.com'dan API key; boşsa dev'de link konsola yazılır
RESEND_API_KEY=""
MAIL_FROM="EmlakFlow <noreply@emlakflow.app>"
# Opsiyonel: Resend webhook doğrulama (Authorization: Bearer … veya x-resend-webhook-secret)
# RESEND_WEBHOOK_SECRET=""

# Kurumsal / white-label iletişim CTA (landing fiyatlandırma)
# NEXT_PUBLIC_ENTERPRISE_CONTACT_URL="mailto:hello@emlakflow.app?subject=Kurumsal%20Demo"
# veya Cal.com / form URL'si

# White-label: Vercel Domains API (Super Admin "Vercel'e domain ekle")
# Vercel → Account Settings → Tokens → Create
# Project Settings → General → Project ID
# VERCEL_TOKEN=""
# VERCEL_PROJECT_ID=""
# VERCEL_TEAM_ID=""   # team hesabıysa
# PLATFORM_HOSTS="emlakflow.app,www.emlakflow.app"  # opsiyonel ek platform host'ları
