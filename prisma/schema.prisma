// ─────────────────────────────────────────────────────────────
// EmlakFlow · Prisma Schema (ESAPP Vertical)
// Next.js + Prisma + Neon (PostgreSQL)
// Çok kiracılı: satır bazlı izolasyon → her tablo `tenantId` taşır.
// İzolasyon lib/tenant.ts içindeki forTenant() extension ile zorlanır.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums ──

// İş kolu (dikey): aynı altyapı, farklı ürün deneyimi.
// REAL_ESTATE → EmlakFlow, AUTO_DEALER → GaleriFlow. MULTI ileride açılır.
enum Vertical {
  REAL_ESTATE
  AUTO_DEALER
  MULTI
}

enum Role {
  OWNER      // Ofis sahibi / broker yetkilisi
  BROKER
  AGENT      // Danışman
  ASSISTANT
}

enum ContactType {
  BUYER
  SELLER
  TENANT_C   // kiracı
  LANDLORD   // mülk sahibi
  OTHER
}

enum LeadStatus {
  OPEN
  MATCHED
  CONVERTED
  LOST
}

// Super-admin pazarlama kampanyası lead durumu (CRM LeadStatus'tan bağımsız)
enum MarketingLeadStatus {
  PENDING
  SENT
  OPENED
  CLICKED
  REJECTED
  DEMO_BOOKED
}

enum ListingPurpose {
  SALE
  RENT
}

enum ListingType {
  // Emlak (REAL_ESTATE)
  APARTMENT
  HOUSE
  VILLA
  LAND
  COMMERCIAL
  OFFICE
  // Araç (AUTO_DEALER)
  SEDAN
  HATCHBACK
  SUV
  PICKUP
  MINIVAN
  COMMERCIAL_VEHICLE
  MOTORCYCLE
}

enum ListingStatus {
  DRAFT
  ACTIVE
  OPTIONED   // opsiyonlandı — fırsat "Sözleşme" aşamasına girince otomatik geçer
  PASSIVE
  SOLD
  RENTED
}

enum DealStage {
  NEW
  CONTACTED
  VIEWING     // yer gösterme
  OFFER
  CONTRACT
  CLOSED_WON
  CLOSED_LOST
}

enum AppointmentStatus {
  SCHEDULED
  DONE
  CANCELLED
  NO_SHOW
}

enum ContractType {
  AUTHORIZATION   // yetki belgesi
  VIEWING_FORM    // yer gösterme formu
  SALE_CONTRACT
  RENT_CONTRACT
}

enum ActivityType {
  CALL
  MEETING
  NOTE
  EMAIL
  WHATSAPP
  STATUS_CHANGE
}

enum EventType {
  IMPRESSION // vitrin listesinde karta görünüm
  VIEW       // ilan detay sayfası açılışı
  CLICK      // telefon / WhatsApp tıklaması
  CONTACT    // lead formu gönderimi
  CHAT       // canlı sohbet başlatma
}

enum InsightSeverity {
  INFO
  ACTION
  URGENT
}

// AI drone video üretim durumu (Vertex AI Veo + QStash webhook)
enum AiVideoStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// AI Stüdyo işlem türü
enum StudioJobType {
  IMAGE_ENHANCE    // fotoğraf iyileştirme / eşyalandırma
  VIDEO_GENERATE   // sahne bazlı video üretimi (Fal.ai / Kling)
  VOICE_GENERATE   // seslendirme üretimi (ElevenLabs)
  VIDEO_MERGE      // sahneleri + sesi tek videoda birleştirme
}

// AI Stüdyo işlem durumu
enum StudioJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// AI sağlayıcı — lib/ai-provider-registry.ts ile bire bir eşleşir
enum AiProvider {
  FAL_KLING   // Fal.ai üzerinden Kling (video)
  FAL_SDXL    // Fal.ai üzerinden SDXL (fotoğraf iyileştirme)
  ELEVENLABS  // ElevenLabs (seslendirme)
}

// AI Stüdyo proje durumu (NLE zaman çizelgesi yaşam döngüsü)
enum StudioProjectStatus {
  DRAFT      // kullanıcı timeline üzerinde çalışıyor
  RENDERING  // sahne/ses/birleştirme işleri sürüyor
  COMPLETED  // nihai video hazır
  FAILED
}

// ── Kira takibi ──

enum RentalStatus {
  ACTIVE
  ENDED
  CANCELLED
}

enum RentalPeriod {
  MONTHLY // emlak: aylık konut/işyeri kirası
  WEEKLY  // araç kiralama
  DAILY   // araç kiralama
}

// ── Görev yönetimi ──

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

// ── Sosyal medya ──

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  YOUTUBE
}

// ── Modeller ──

model Tenant {
  id        String   @id @default(cuid())
  name      String   // Ofis / acente / galeri adı
  slug      String   @unique
  phone     String?
  city      String?
  district  String?
  plan      String   @default("trial") // trial | starter | free | pro | premium
  vertical  Vertical @default(REAL_ESTATE) // iş kolu — kayıtta seçilir, ürün deneyimini belirler
  
  // Pro plan yönetimi (Admin paneli)
  proStartedAt  DateTime? // Pro plana geçiş tarihi
  proExpiresAt  DateTime? // Pro planın bitiş tarihi (null = sınırsız)
  adminNotes    String?   // Sadece admin panelinde görünen notlar

  // AI Stüdyo kredi havuzu (ofis geneli — plan bazlı aylık reset)
  aiImageCredits     Int      @default(10)   // kalan fotoğraf iyileştirme hakkı
  aiVideoCredits     Int      @default(3)    // kalan video üretme hakkı
  aiCreditsResetAt   DateTime @default(now()) // son kredi reset tarihi

  // Komisyon ayarları (Ayarlar sayfasından düzenlenecek)
  commissionRate Decimal @default(4.0) @db.Decimal(5, 2) // satışta % oran
  agentSharePct  Int     @default(50)                    // danışman payı %

  // Portal / XML yayın ayarları (Ayarlar sayfasından)
  portalSahibinden Boolean @default(false)
  portalHepsiemlak Boolean @default(false)
  portalEmlakjet   Boolean @default(false)
  // Otomotiv portalları (AUTO_DEALER dikeyi)
  portalArabam         Boolean @default(false)
  portalSahibindenAuto Boolean @default(false)
  feedToken        String? @unique // public feed URL anahtarı (lazy üretilir)

  // Sözleşme şablonu (Ayarlar > Sözleşme Şablonu — otomatik taslak üretiminde kullanılır)
  contractCompanyTitle   String? // resmi unvan (boşsa `name` kullanılır)
  contractRepresentative String? // yetkili temsilci adı
  contractAddress        String? // sözleşme başlığındaki açık adres
  contractTaxNo          String? // vergi no / ticaret sicil no
  contractExtraClauses   String? // sözleşme sonuna eklenen ek madde metni

  // Vitrin (public ofis sayfası) ayarları
  showcaseEnabled Boolean @default(true)
  showcaseTagline String? // kahraman başlığın altındaki tanıtım cümlesi
  whatsapp        String? // vitrin WhatsApp hattı (boşsa telefon kullanılır)
  aboutTitle      String? // Hakkımızda başlığı
  aboutText       String? // Hakkımızda metni
  visionText      String? // Vizyon alıntısı
  aboutStats      Json?   // [{value,label}] x3 — istatistik plakaları
  showTeam        Boolean @default(true) // ekip şeridi görünür mü

  // Marka kişiselleştirme (vitrin teması — müşteri Ayarlar'dan da düzenleyebilir)
  brandColor      String? // hex renk kodu, örn. "#1e5b3e" — vitrinde CSS variable olarak enjekte edilir
  logoUrl         String? // R2'deki ofis logosu URL'si
  logoKey         String? // R2 object key
  officePhotoUrl  String? // Hakkımızda bölümündeki ofis fotoğrafı
  officePhotoKey  String?

  // White-label (yalnızca Super Admin — özel alan adı + kurumsal markalama)
  customDomain    String? @unique // örn. www.emlakofisi.com (host, protokolsüz)
  brandName       String? // vitrinde EmlakFlow yerine gösterilecek marka adı
  primaryColor    String? // kurumsal ana renk (hex); brandColor ile senkron tutulabilir

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  contacts     Contact[]
  leads        Lead[]
  listings     Listing[]
  deals        Deal[]
  appointments Appointment[]
  contracts    Contract[]
  commissions  Commission[]
  cashEntries  CashEntry[]
  activities   Activity[]
  notifications Notification[]
  messages     Message[]
  listingEvents ListingEvent[]
  dailyStats   ListingDailyStat[]
  insights     Insight[]
  planChanges  PlanChangeLog[]
  siteUsers    SiteUser[]
  rentals      RentalAgreement[]
  rentPayments RentPayment[]
  tasks        Task[]
  socialAccounts SocialAccount[]
  socialPosts    SocialPost[]
  teamChatReads  TeamChatRead[]
  emailLogs      EmailLog[]
  studioJobs     StudioJob[]
  studioProjects StudioProject[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  role         Role     @default(AGENT)
  avatarUrl    String?
  photoUrl     String? // ekip vitrininde gösterilen fotoğraf (avatarUrl'den ayrı)
  photoKey     String? // R2 object key
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings     Listing[]
  deals        Deal[]
  appointments Appointment[]
  commissions  Commission[]
  cashEntries  CashEntry[]
  activities   Activity[]
  notifications Notification[]
  tasks        Task[]
  teamChatReads TeamChatRead[]
  studioJobs    StudioJob[]
  studioProjects StudioProject[]

  @@index([tenantId])
}

model Contact {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      ContactType @default(BUYER)
  fullName  String
  phone     String?
  email     String?
  note      String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  leads        Lead[]
  deals        Deal[]
  appointments Appointment[]
  contracts    Contract[]
  rentals      RentalAgreement[]
  siteUser     SiteUser?

  @@index([tenantId])
  @@index([tenantId, phone])
}

model Lead {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId String?
  contact   Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  status    LeadStatus @default(OPEN)
  source    String?    // sahibinden, referans, tabela, instagram…

  // Arama kriterleri (eşleştirme motoru girdisi)
  purpose   ListingPurpose @default(SALE)
  type      ListingType?
  city      String?
  district  String?
  neighborhoods String[]   @default([])
  rooms     String?        // "3+1" formatı
  minArea   Int?           // net m²
  maxArea   Int?
  minPrice  Decimal?       @db.Decimal(14, 2)
  maxPrice  Decimal?       @db.Decimal(14, 2)
  needsCredit Boolean      @default(false) // krediye uygunluk şartı
  note      String?

  // Araç arama kriterleri (AUTO_DEALER dikeyi — eşleştirme motoru girdisi)
  vehicleBrand String? // "Volkswagen"
  vehicleModel String? // "Passat"
  minYear      Int?
  maxKm        Int?
  fuel         String? // benzin | dizel | hibrit | elektrik | lpg
  transmission String? // manuel | otomatik

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals Deal[]

  @@index([tenantId, status])
}

model Listing {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agentId   String?
  agent     User?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  refCode   String         // EF-2026-0001 — ofis içi referans
  title     String
  purpose   ListingPurpose @default(SALE)
  type      ListingType    @default(APARTMENT)
  status    ListingStatus  @default(ACTIVE)

  price     Decimal  @db.Decimal(14, 2)
  currency  String   @default("TRY")

  // Lokasyon
  city         String
  district     String
  neighborhood String?
  address      String?
  lat          Float?
  lng          Float?

  // Türkiye'ye özgü fiziksel özellikler
  rooms        String?  // "3+1"
  grossArea    Int?     // brüt m²
  netArea      Int?     // net m²
  floor        Int?
  totalFloors  Int?
  buildingAge  Int?
  heating      String?  // kombi, merkezi, yerden…
  dues         Decimal? @db.Decimal(10, 2) // aidat
  deedStatus   String?  // tapu durumu: kat mülkiyeti, kat irtifakı, arsa…
  creditEligible Boolean @default(true)    // krediye uygun
  furnished    Boolean  @default(false)
  inSite       Boolean  @default(false)    // site içinde
  description  String?
  // Hızlı eklenen özellik çipleri: "Asansör", "Otopark", "Balkon"…
  features     String[] @default([])

  // ── Araç alanları (AUTO_DEALER dikeyi — emlakta null kalır) ──
  vehicleBrand   String? // "Volkswagen"
  vehicleModel   String? // "Passat 1.6 TDI"
  vehicleYear    Int?    // model yılı
  vehicleKm      Int?
  fuel           String? // benzin | dizel | hibrit | elektrik | lpg
  transmission   String? // manuel | otomatik | yarı otomatik
  engineSize     String? // "1.6", "2.0"
  enginePower    Int?    // HP
  color          String?
  bodyType       String? // sedan, hatchback… (ListingType araç değerleriyle örtüşür)
  tramerAmount   Decimal? @db.Decimal(12, 2) // tramer kaydı tutarı (null = bilinmiyor, 0 = yok)
  plateNumber    String?  // plaka — vitrine yansıtılmaz, ofis içi
  exchangeOk     Boolean  @default(false) // takas kabul
  warrantyOk     Boolean  @default(false) // garantisi devam ediyor
  // Kiralık araç fiyatlandırması (purpose=RENT iken)
  rentDailyPrice  Decimal? @db.Decimal(12, 2)
  rentWeeklyPrice Decimal? @db.Decimal(12, 2)
  rentDeposit     Decimal? @db.Decimal(12, 2)

  // Portal XML feed'e dahil et (ilan başına toggle)
  feedEnabled    Boolean  @default(true)

  // Vitrin vitrininde "Öne Çıkanlar" rafında göster
  featured       Boolean  @default(false)

  // Otomatik SEO
  seoTitle       String?
  seoDescription String?
  slug           String? // URL dostu ek: /ofis/[slug]/ilan/[id]-[slug]

  // AI drone videosu (Mapbox statik görüntü → Vertex AI Veo → Vercel Blob)
  aiDroneVideoUrl String?
  aiVideoStatus   AiVideoStatus?

  // Konum ve Çevre Analizörü (Overpass/OSM) — Çevresel Değerlendirme Puanı
  environmentScore Int?  // 0-100
  environmentData  Json? // kategori kırılımı: en yakın metro/okul/hastane vb.
  // Harita üzerinde işaretlenen alan sınırı (tarla/arsa için poligon).
  // GeoJSON Polygon coordinates: [[[lng,lat],...]]. Daire/dükkan için null (nokta lat/lng yeterli).
  parcelGeo    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media        ListingMedia[]
  deals        Deal[]
  appointments Appointment[]
  contracts    Contract[]
  events       ListingEvent[]
  dailyStats   ListingDailyStat[]
  insights     Insight[]
  favorites    Favorite[]
  rentals      RentalAgreement[]
  tasks        Task[]
  socialPosts  SocialPost[]
  studioJobs   StudioJob[]
  studioProjects StudioProject[]

  @@unique([tenantId, refCode])
  @@index([tenantId, status])
  @@index([tenantId, city, district])
}

model ListingMedia {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String  // R2 public URL (orijinal / full boyut)
  key       String  // R2 object key
  kind      String  @default("photo") // photo | video | tour360 | floorplan
  order     Int     @default(0)

  // Sunucu tarafı (sharp) üretilen optimize varyantlar — yoksa `url` kullanılır
  thumbUrl  String? // 400px — küçük önizleme
  cardUrl   String? // 960px — vitrin kartı
  width     Int?    // orijinal genişlik
  height    Int?    // orijinal yükseklik
  alt       String? // SEO alt metni

  createdAt DateTime @default(now())

  videoScenes VideoScene[] // bu fotoğraftan üretilen AI Stüdyo sahneleri

  @@index([listingId])
}

model Deal {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stage     DealStage @default(NEW)
  listingId String?
  listing   Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  leadId    String?
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contactId String?
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  agentId   String?
  agent     User?     @relation(fields: [agentId], references: [id], onDelete: SetNull)
  value     Decimal?  @db.Decimal(14, 2) // beklenen işlem bedeli
  closedAt  DateTime?
  lostReason String?
  stageChangedAt DateTime @default(now()) // aşamaya giriş anı — "bayat fırsat" rozetinde kullanılır
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  commissions Commission[]
  contracts   Contract[]

  @@index([tenantId, stage])
}

model Appointment {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String
  status    AppointmentStatus @default(SCHEDULED)
  startsAt  DateTime
  endsAt    DateTime?
  listingId String?
  listing   Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  contactId String?
  contact   Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  agentId   String?
  agent     User?             @relation(fields: [agentId], references: [id], onDelete: SetNull)
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([tenantId, startsAt])
}

model Contract {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      ContractType
  listingId String?
  listing   Listing?     @relation(fields: [listingId], references: [id], onDelete: SetNull)
  contactId String?
  contact   Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId    String?      // hangi fırsata (Deal) bağlı — anlaşılan bedeli buradan alır
  deal      Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  fileUrl   String?      // R2'deki taranmış/imzalı belge (PDF ya da fotoğraf)
  fileKey   String?      // R2 object key — silme için
  signedAt  DateTime?
  expiresAt DateTime?    // yetki belgesi bitişi
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([tenantId, type])
  @@index([tenantId, dealId])
}

model Commission {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  agentId   String?
  agent     User?    @relation(fields: [agentId], references: [id], onDelete: SetNull)
  gross     Decimal  @db.Decimal(14, 2) // toplam komisyon
  agentShare  Decimal @db.Decimal(14, 2) // danışman payı
  officeShare Decimal @db.Decimal(14, 2) // ofis payı
  paidAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

/// Manuel kasa hareketi — komisyon dışı gelir/gider (kira, reklam, ofis gideri vb.)
model CashEntry {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String   // "income" | "expense"
  amount      Decimal  @db.Decimal(14, 2)
  title       String
  note        String?
  category    String?  // örn. "reklam", "kira", "ofis", "diğer"
  occurredAt  DateTime @default(now())
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, type])
}

model Activity {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      ActivityType
  userId    String?
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity    String?      // "listing" | "deal" | "lead" | "contact"
  entityId  String?
  body      String
  createdAt DateTime     @default(now())

  @@index([tenantId, createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  href      String?   // tıklanınca gidilecek sayfa
  readAt    DateTime?
  category  String    @default("system") // "lead" | "match" | "chat" | "team" | "deal" | "contract" | "appointment" | "system"
  severity  String    @default("info")   // "info" | "action" | "urgent"
  createdAt DateTime  @default(now())

  @@index([tenantId, userId, readAt])
  @@index([tenantId, userId, category])
}

// Kullanıcı başına sohbet okuma imleci — grup (TEAM) ve DM oturumları.
model TeamChatRead {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String   @default("TEAM")
  lastReadAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, userId, sessionId])
}

// Vitrin funnel olayları (Impression → View → Click → Contact).
// Yüksek hacim beklenir: id bigserial (cuid string indeksinden ~%70 küçük),
// zaman-serisi taramaları için BRIN. Ham kayıt 90 gün tutulur, gecelik cron
// ListingDailyStat'a özetler (bkz. api/cron/rollup).
model ListingEvent {
  id        BigInt    @id @default(autoincrement())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId String?   // CHAT gibi ilandan bağımsız olaylarda null
  listing   Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  type      EventType
  sessionId String?   // ziyaretçi oturumu (v_xxx) — sohbet oturumuyla ortak anahtar
  source    String?   // "vitrin" | "feed:sahibinden" | "qr" …
  durationMs Int?     // VIEW için sayfada kalma süresi (pagehide beacon'ı ile güncellenir)
  createdAt DateTime  @default(now())

  @@index([tenantId, listingId, type, createdAt])
  @@index([tenantId, sessionId])
  @@index([createdAt], type: Brin)
}

// Emlakçıya eylem odaklı öneri (IF/THEN motoru — api/cron/rollup gecelik üretir).
model Insight {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId   String?
  listing     Listing?        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  rule        String          // "DOM_HIGH" | "PRICE_ABOVE_MARKET" | "STALE_LEAD" | "AUTH_EXPIRING" …
  severity    InsightSeverity @default(ACTION)
  title       String
  body        String
  data        Json?           // hesaplama kanıtı
  dismissedAt DateTime?
  createdAt   DateTime        @default(now())

  @@index([tenantId, dismissedAt, createdAt])
  @@index([tenantId, listingId, rule])
}

// Günlük özet — ham eventler budandıktan sonra kalıcı analitik kaynağı.
model ListingDailyStat {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  day         DateTime @db.Date
  impressions Int      @default(0)
  views       Int      @default(0)
  clicks      Int      @default(0)
  contacts    Int      @default(0)
  chats       Int      @default(0)

  @@unique([tenantId, listingId, day])
  @@index([tenantId, day])
}

model Message {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  senderId  String?  // user.id if agent, null if visitor
  senderName String? // name for visitor
  senderPhone String? // optional visitor phone (vitrin chat)
  sessionId String?  // grouping identifier for vitrin visitors, or "TEAM" for internal team chat
  body      String

  // Ek (fotoğraf/video) — R2'ye doğrudan yüklenir, mesaja bağlanır
  attachmentUrl  String?
  attachmentType String? // "image" | "video"

  // Konum paylaşımı — tarayıcı Geolocation API'siyle alınır
  lat Float?
  lng Float?

  createdAt DateTime @default(now())

  @@index([tenantId, sessionId, createdAt])
}

// ── Vitrin son kullanıcısı (alıcı/kiracı) ──
// Emlakçı (User) hesabından tamamen bağımsız: ofis vitrin sitesine üye olur,
// favori ilan kaydeder. Oturum, NextAuth'a dokunmadan jose JWT cookie ile tutulur.
model SiteUser {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String
  passwordHash String
  phone        String?
  contactId    String?  @unique
  contact      Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  favorites Favorite[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Favorite {
  id         String   @id @default(cuid())
  siteUserId String
  siteUser   SiteUser @relation(fields: [siteUserId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([siteUserId, listingId])
  @@index([listingId])
}

// ── Kira Takibi ──
// Ofisin/danışmanın kendi kiraya verdiği mülkler (emlak) veya kiralık araç
// sözleşmeleri (galeri). Portföydeki bir ilana bağlanabilir ama zorunlu değil.
model RentalAgreement {
  id        String       @id @default(cuid())
  tenantId  String
  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listingId String?
  listing   Listing?     @relation(fields: [listingId], references: [id], onDelete: SetNull)
  contactId String
  contact   Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  title     String       // ilana bağlı değilse serbest ad: "Çankaya 2+1 dairem"
  status    RentalStatus @default(ACTIVE)
  period    RentalPeriod @default(MONTHLY)

  startDate DateTime     // ne zaman kiralandı
  endDate   DateTime     // ne zamana kadar
  rentAmount Decimal     @db.Decimal(12, 2) // dönem başına kira bedeli
  currency  String       @default("TRY")
  deposit   Decimal?     @db.Decimal(12, 2)
  paymentDueDay Int      @default(1) // ayın kaçında ödenir (MONTHLY için, 1–31)
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments RentPayment[]

  @@index([tenantId, status])
  @@index([tenantId, endDate])
}

model RentPayment {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agreementId String
  agreement   RentalAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  periodLabel String          // "2026-07" (aylık) ya da gün/hafta aralığı etiketi
  dueDate     DateTime
  amount      Decimal         @db.Decimal(12, 2)
  paidAt      DateTime?       // null = ödenmedi
  method      String?         // nakit | havale | kart…
  note        String?
  createdAt   DateTime        @default(now())

  @@unique([agreementId, periodLabel])
  @@index([tenantId, dueDate])
  @@index([tenantId, paidAt])
}

// ── Görev yönetimi ──
// Atanabilir işler: ilan çekimi, video paylaşımı, evrak takibi vb.
model Task {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  listingId  String?
  listing    Listing?     @relation(fields: [listingId], references: [id], onDelete: SetNull)
  socialPostId String?
  socialPost SocialPost?  @relation(fields: [socialPostId], references: [id], onDelete: SetNull)
  title      String
  note       String?
  status     TaskStatus   @default(OPEN)
  priority   TaskPriority @default(NORMAL)
  dueAt      DateTime?
  doneAt     DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([tenantId, status, dueAt])
  @@index([tenantId, assigneeId, status])
}

// ── Sosyal Medya İçerik Takibi ──
// OAuth ile bağlanan hesaplar; token'lar şifrelenmeden saklanmaz varsayımı yok —
// erişim yalnız server tarafında. Meta (IG) ilk platform, diğerleri aynı modeli kullanır.
model SocialAccount {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform     SocialPlatform
  externalId   String         // platformdaki hesap/sayfa id'si (IG Business account id)
  username     String?        // @galeriakdeniz
  displayName  String?
  accessToken  String         // uzun ömürlü token
  refreshToken String?
  expiresAt    DateTime?      // token bitişi — cron yenileme kontrolü
  pageId       String?        // Meta: bağlı Facebook Page id
  lastSyncedAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  posts SocialPost[]

  @@unique([tenantId, platform, externalId])
  @@index([tenantId])
}

// Paylaşılan içerik (video/reel/post) — ilana/araca bağlanabilir.
model SocialPost {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accountId   String?
  account     SocialAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  listingId   String?
  listing     Listing?       @relation(fields: [listingId], references: [id], onDelete: SetNull)
  platform    SocialPlatform
  externalId  String?        // platformdaki medya id'si (API senkronu için)
  url         String         // içerik linki
  kind        String         @default("video") // video | reel | post | story
  caption     String?
  thumbnailUrl String?
  publishedAt DateTime?
  lastSyncedAt DateTime?
  // Son bilinen metrikler (hızlı liste görünümü — tarihçe SocialPostMetric'te)
  views    Int @default(0)
  likes    Int @default(0)
  comments Int @default(0)
  shares   Int @default(0)
  reach    Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metrics SocialPostMetric[]
  tasks   Task[]

  @@unique([tenantId, platform, externalId])
  @@index([tenantId, listingId])
  @@index([tenantId, publishedAt])
}

// Metrik zaman serisi — cron her senkronda anlık değerleri yazar.
model SocialPostMetric {
  id         String     @id @default(cuid())
  postId     String
  post       SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  capturedAt DateTime   @default(now())
  views      Int        @default(0)
  likes      Int        @default(0)
  comments   Int        @default(0)
  shares     Int        @default(0)
  reach      Int        @default(0)

  @@index([postId, capturedAt])
}

// Super-admin pazarlama / outbound lead havuzu.
// Tenant CRM'deki Lead modelinden tamamen bağımsızdır (tenantId yok).
model MarketingLead {
  id           String              @id @default(cuid())
  firmaAdi     String
  yetkiliIsmi  String?
  email        String              @unique
  telefon      String?
  bolge        String?
  notes        String?
  status       MarketingLeadStatus @default(PENDING)
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  lastEmailId  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  emails MarketingOutboundEmail[]

  @@index([status])
  @@index([createdAt])
  @@index([sentAt])
}

/// Super-admin outbound gönderim kaydı — kişiye özel / seçimli kampanya geçmişi
model MarketingOutboundEmail {
  id          String         @id @default(cuid())
  leadId      String
  lead        MarketingLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  templateKey String
  subject     String
  preview     String?
  status      String         // sent | failed | opened | clicked | bounced
  resendId    String?        @unique
  error       String?
  sentAt      DateTime       @default(now())
  openedAt    DateTime?
  clickedAt   DateTime?
  createdAt   DateTime       @default(now())

  @@index([leadId, sentAt])
  @@index([status])
}

// Plan değişiklik geçmişi (Admin panelinde görüntülenir)
model PlanChangeLog {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromPlan    String   // Önceki plan
  toPlan      String   // Yeni plan
  changedBy   String?  // Admin kullanıcı e-postası (veya sistem)
  reason      String?  // Değişiklik nedeni / admin notu
  expiresAt   DateTime? // Pro ise bitiş tarihi
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
}

// Giden e-posta kaydı — sohbet/e-posta merkezinde listelenir,
// randevu hatırlatmalarında mükerrer gönderim kontrolü refId ile yapılır.
model EmailLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  to        String
  toName    String?
  kind      String   // office-welcome | site-welcome | new-listing | price-drop | appointment | custom
  subject   String
  preview   String?  // düz metin özeti (liste görünümü için)
  status    String   @default("sent") // sent | failed
  error     String?
  listingId String?
  contactId String?
  refId     String?  // ör. appointmentId — aynı kayda ikinci maili engeller
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([refId, kind])
}

// ── AI Stüdyo İşlem Geçmişi ──
// Fotoğraf iyileştirme ve video üretim işlerini takip eder.
// Tenant kredi havuzundan düşülen işlemler burada loglanır.
model StudioJob {
  id         String           @id @default(cuid())
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  type       StudioJobType
  status     StudioJobStatus  @default(PENDING)

  // Sahne bazlı proje bağlantısı (eski tekil işler için null)
  projectId  String?
  project    StudioProject?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Bu işin aktif olarak bağlı olduğu sahne (VideoScene.jobId üzerinden bire bir)
  activeScene VideoScene?

  // Giriş
  inputMediaId     String?        // ilana ait orijinal fotoğraf (IMAGE_ENHANCE)
  inputUrl         String?        // orijinal fotoğraf URL'si
  videoConceptKey  String?        // drone | interior | social (VIDEO_GENERATE)
  selectedMediaIds String[]       @default([]) // video için seçilen fotoğraf id'leri

  // Çıktı
  outputUrl    String?        // AI çıktısı URL'si (R2)
  outputKey    String?        // R2 object key
  errorMessage String?

  creditCost         Int     @default(1)     // düşülen kredi miktarı
  appliedToListing   Boolean @default(false) // çıktı ilana entegre edildi mi

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([tenantId, listingId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([projectId])
}

// ── AI Stüdyo: Sahne Bazlı Video Projesi (NLE) ──
// Bir proje = bir ilanın tanıtım videosu. Video tek parça üretilmez;
// timeline üzerindeki VideoScene kayıtları tek tek render edilir,
// ardından VIDEO_MERGE işiyle seslendirme eklenerek birleştirilir.
model StudioProject {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)

  title     String
  status    StudioProjectStatus @default(DRAFT)

  // Çıktı formatı
  aspectRatio String @default("16:9") // 16:9 | 9:16 (sosyal medya) | 1:1

  // Seslendirme (proje geneli — ElevenLabs)
  voiceText     String?     // seslendirme metni (AI ile üretilebilir)
  voiceProvider AiProvider? // şimdilik hep ELEVENLABS
  voiceUrl      String?     // üretilen ses dosyası (R2)
  voiceKey      String?     // R2 object key

  // Nihai birleştirilmiş video (VIDEO_MERGE çıktısı)
  finalVideoUrl String?
  finalVideoKey String?
  errorMessage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scenes VideoScene[]
  jobs   StudioJob[]

  @@index([tenantId, listingId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

// ── AI Stüdyo: Timeline Sahnesi ──
// Her sahne tek başına render edilir ve tek başına "Regenerate" edilebilir.
// jobId her zaman sahnenin AKTİF (son) StudioJob kaydını gösterir;
// yeniden üretimde yeni bir StudioJob açılır ve jobId güncellenir.
model VideoScene {
  id        String        @id @default(cuid())
  projectId String
  project   StudioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  order Int @default(0) // timeline sırası

  // Giriş: sahnenin üretileceği kaynak fotoğraf
  sourceImageId  String?
  sourceImage    ListingMedia? @relation(fields: [sourceImageId], references: [id], onDelete: SetNull)
  sourceImageUrl String        // medya silinse bile render girdisi korunur

  prompt      String                        // sahne kamera/hareket yönergesi
  provider    AiProvider      @default(FAL_KLING)
  durationSec Int             @default(5)   // Kling: 5 | 10
  status      StudioJobStatus @default(PENDING)

  // Çıktı
  outputUrl    String? // render edilmiş sahne klibi (R2)
  outputKey    String? // R2 object key
  errorMessage String?

  // Aktif render işi — timeline arayüzü durumunu buradan izler
  jobId String?    @unique
  job   StudioJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, order])
  @@index([projectId, status])
}
